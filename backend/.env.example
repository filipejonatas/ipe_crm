PORT=3001
FRONTEND_URL=http://localhost:3000

# Supabase usa PostgreSQL.
# Opcao recomendada: use a connection string do Supabase.
# DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<SENHA>@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Opcao alternativa: campos separados.
DB_HOST=aws-0-sa-east-1.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.<PROJECT_REF>
DB_PASS=<SENHA_DO_BANCO>
DB_NAME=postgres
DB_SSL=true

JWT_SECRET=troque_por_secret_seguro
JWT_EXPIRES_IN=8h
