{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@ipe_crm/shared": ["../packages/shared/src/index.ts"],
      "@ipe_crm/shared/*": ["../packages/shared/src/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
